<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <title>Gaming Gaiden - Session History</title>
    <link rel="icon" type="image/x-icon" href="./resources/images/favicon.ico" />
    <link rel="stylesheet" href="./resources/css/theme.css" />
    <link rel="stylesheet" href="./resources/css/common.css" />
    <link rel="stylesheet" href="./resources/css/calendar-controls.css" />
    <link rel="stylesheet" href="./resources/css/SessionHistory/SessionHistory-shared.css" />
    <link rel="stylesheet" href="./resources/css/SessionHistory/SessionHistory-games.css" />
    <link rel="stylesheet" href="./resources/css/SessionHistory/SessionHistory-calendar.css" />
    <link rel="stylesheet" href="./resources/css/SessionHistory/SessionHistory-cards.css" />
    <script src="./resources/js/libraries/jquery-3.7.1.min.js"></script>
    <script src="./resources/js/libraries/chart.js"></script>
    <script src="./resources/js/libraries/chartjs-plugin-datalabels-2.0.0.js"></script>
    <script>
    //<![CDATA[
      $(document).ready(function () {
        // Standard table header processing
        $("table").each(function () {
          var tHead = $(this).find("tr:first").html();
          $(this).find("colgroup").remove();
          $(this).find("tr:first").remove();
          $(this).find("tbody").before("<thead>" + tHead + "</thead>");
        });
      });
    //]]>
    </script>
  </head>
  <body>
    <h1>Session History</h1>

    <!-- Two-column layout container -->
    <div id="main-container">

      <!-- LEFT COLUMN: View Buttons + Content -->
      <div id="left-column">
        <!-- View Switcher Buttons -->
        <div id="view-buttons">
          <button class="view-btn active" data-view="games">Games</button>
          <button class="view-btn" data-view="byday">By Day</button>
          <button class="view-btn" data-view="bymonth">By Month</button>
        </div>

        <!-- Games View Content -->
        <div id="games-view-content" class="left-content">
          <div id="search-container">
            <input
              type="text"
              id="game-search"
              placeholder="Search games..."
              autocomplete="off"
            />
          </div>

          <div id="sort-container">
            <button id="sort-by-name" class="sort-btn">
              Name <span class="sort-arrow">▼</span>
            </button>
            <button id="sort-by-last-played" class="sort-btn active">
              Last Played <span class="sort-arrow">▼</span>
            </button>
            <button id="sort-by-hours" class="sort-btn">
              Hours <span class="sort-arrow">▼</span>
            </button>
            <button id="sort-by-days" class="sort-btn">
              Days <span class="sort-arrow">▼</span>
            </button>
          </div>

          <div id="games-list-container">
            <ul id="games-list">
              <!-- Populated by JavaScript -->
            </ul>
          </div>
        </div>

        <!-- Calendar View Content (for By Day and By Month) -->
        <div id="calendar-view-content" class="left-content" style="display: none;">
          <div id="calendar-container">
            <!-- Year Navigation -->
            <div id="year-navigation">
              <button class="custom-button calendar-nav-btn" id="prev-year-button">&#11164;</button>
              <div id="year-display"></div>
              <button class="custom-button calendar-nav-btn" id="next-year-button">&#11166;</button>
            </div>

            <!-- Month Grid -->
            <div id="month-grid">
              <button class="month-btn" data-month="0">Jan</button>
              <button class="month-btn" data-month="1">Feb</button>
              <button class="month-btn" data-month="2">Mar</button>
              <button class="month-btn" data-month="3">Apr</button>
              <button class="month-btn" data-month="4">May</button>
              <button class="month-btn" data-month="5">Jun</button>
              <button class="month-btn" data-month="6">Jul</button>
              <button class="month-btn" data-month="7">Aug</button>
              <button class="month-btn" data-month="8">Sep</button>
              <button class="month-btn" data-month="9">Oct</button>
              <button class="month-btn" data-month="10">Nov</button>
              <button class="month-btn" data-month="11">Dec</button>
            </div>

            <!-- Day Grid (only shown in By Day view) -->
            <div id="day-grid-container">
              <div id="selected-month-display"></div>
              <div id="day-headers">
                <div class="day-header weekend">Su</div>
                <div class="day-header">Mo</div>
                <div class="day-header">Tu</div>
                <div class="day-header">We</div>
                <div class="day-header">Th</div>
                <div class="day-header">Fr</div>
                <div class="day-header weekend">Sa</div>
              </div>
              <div id="day-grid">
                <!-- Populated by JavaScript -->
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN: Chart or Game Cards -->
      <div id="right-column">
        <!-- Games View: Chart -->
        <div id="games-view-right" class="right-content">
          <div id="selected-game-header">
            <h2 id="selected-game-name">Select a game to view sessions</h2>
            <div id="selected-game-stats">
              <div class="stat-item">
                <span class="stat-label">Platform:</span>
                <span class="stat-value" id="stat-platform"></span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Sessions:</span>
                <span class="stat-value" id="stat-sessions"></span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Days:</span>
                <span class="stat-value" id="stat-days"></span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Total Time:</span>
                <span class="stat-value" id="stat-hours"></span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Last Played:</span>
                <span class="stat-value" id="stat-last-played"></span>
              </div>
            </div>
          </div>

          <div id="chart-container">
            <div id="day-night-play-bar" class="day-night-play-bar" aria-label="Play time by session start: night vs day">
              <span class="day-night-play-bar__moon" aria-hidden="true">
                <svg class="day-night-play-bar__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                  <path fill="#E8DFC0" stroke="#5E6369" stroke-width="1.45" stroke-linejoin="round" stroke-linecap="round"
                    d="M18.36 4.64A9 9 0 1 0 21 12a6.5 6.5 0 1 1 -2.64 -7.36z"/>
                  <circle fill="#C4B799" cx="8.2" cy="5.1" r="0.55"/>
                  <circle fill="#C4B799" cx="6" cy="10.2" r="1.2"/>
                  <circle fill="#C4B799" cx="7.4" cy="15" r="0.85"/>
                  <circle fill="#C4B799" cx="12.2" cy="18.5" r="0.65"/>
                </svg>
              </span>
              <div class="day-night-play-bar__track">
                <div class="day-night-play-bar__night">
                  <span id="day-night-play-night-label" class="day-night-play-bar__label"></span>
                </div>
                <div class="day-night-play-bar__twilight" aria-hidden="true"></div>
                <div class="day-night-play-bar__day">
                  <span id="day-night-play-day-label" class="day-night-play-bar__label"></span>
                </div>
              </div>
              <span class="day-night-play-bar__sun" aria-hidden="true">
                <svg class="day-night-play-bar__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                  <path fill="#FEF8C8" stroke="#5E6369" stroke-width="1.45" stroke-linejoin="round" stroke-linecap="round"
                    d="M12 1.8 15.38 4.97 19.97 5.64 19.6 10.26 21.94 14.27 18.1 16.86 16.43 21.19 12 19.8 7.57 21.19 5.9 16.86 2.06 14.27 4.4 10.26 4.03 5.64 8.62 4.97z"/>
                </svg>
              </span>
            </div>
            <canvas id="session-chart"></canvas>
            <button class="custom-button" id="return-button">Return</button>
          </div>

          <div id="no-selection-message">
            <p>Select a game from the list to view its session history</p>
          </div>
        </div>

        <!-- Day/Month View: Game Cards Grid -->
        <div id="cards-view-right" class="right-content" style="display: none;">
          <div id="cards-header">
            <h2 id="selected-date-title">Games Played</h2>
            <div id="date-stats">
              <span id="total-games-count"></span>
              <span id="total-time-played"></span>
            </div>
          </div>
          <div id="game-cards-grid">
            <!-- Populated by JavaScript -->
          </div>
          <div id="no-games-message" style="display: none;">
            <p>No games played on this date</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Hidden data tables for JavaScript parsing -->
    <div style="display: none">
      <div id="sessions-data">_SESSIONTABLE_</div>
      <div id="games-data">_GAMESTABLE_</div>
    </div>

    <script src="./resources/js/common.js"></script>
    <script src="./resources/js/calendar-controls.js"></script>
    <script src="./resources/js/SessionHistory/SessionHistory-shared.js"></script>
    <script src="./resources/js/SessionHistory/SessionHistory-games.js"></script>
    <script src="./resources/js/SessionHistory/SessionHistory-calendar.js"></script>
    <script src="./resources/js/SessionHistory/SessionHistory-cards.js"></script>

    <!-- Navigation Bar -->
    <div id="navigation-bar">
      <button class="custom-button" id="summary-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/Summary.html'">Life Time Summary</button>
      <button class="custom-button" id="gaming-time-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/GamingTime.html'">Time Spent Gaming</button>
      <button class="custom-button" id="most-played-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/MostPlayed.html'">Most Played</button>
      <button class="custom-button" id="all-games-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/AllGames.html'">All Games</button>
      <button class="custom-button help-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/Manual.html'">?</button>
      <button class="custom-button" id="idle-time-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/IdleTime.html'">Idle Time</button>
      <button class="custom-button" id="session-history-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/SessionHistory.html'">Session History</button>
      <button class="custom-button" id="games-per-platform-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/GamesPerPlatform.html'">Games / Platform</button>
      <button class="custom-button" id="pc-vs-emu-button" onclick="window.location.href='file:///C:/ProgramData/GamingGaiden/ui/PCvsEmulation.html'">PC vs Emulation</button>
    </div>
  </body>
</html>
